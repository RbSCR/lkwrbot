<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find lkwrbot_description)/urdf/inertia_tensors.urdf.xacro"/>

  <!-- xacro:include filename="$(find lkwrbot_description)/urdf/base.control.xacro"  TODO remove, now in base.urdf.xacro -->

  <xacro:macro name="lkwrbot_base_module" params="parent *origin">

    <xacro:include filename="$(find lkwrbot_description)/urdf/base.materials.xacro"/>


    <!-- Mount base_link to parent platform at specified origin -->
    <joint name="lkwrbot_mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="bottom_base_plate_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <!-- === Links === -->

    <!-- Bottom base plate -->
    <link name="bottom_base_plate_link">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 -${pi/2}"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/base_plate_layer1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="base_material"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
        <geometry>
          <cylinder length="${base_plate_height}" radius="${base_plate_diameter/2}"/>
        </geometry>
      </collision>
      <xacro:inertial_cylinder mass="${bottom_base_plate_mass}" radius="${base_plate_diameter/2}" length="${base_plate_height}"/>
    </link>

    <!-- Top base plate -->
    <link name="top_base_plate_link">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 -${pi/2}" />
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/base_plate_layer2.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="base_material"/>
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
        <geometry>
          <cylinder length="${base_plate_height}" radius="${base_plate_diameter/2}"/>
        </geometry>
      </collision>
      <xacro:inertial_cylinder mass="${top_base_plate_mass}" radius="${base_plate_diameter/2}" length="${base_plate_height}"/>
    </link>

    <!-- Left motor mount -->
    <link name="left_motormount_link">
      <visual>
        <origin xyz="-${motormount_depth/2} ${motormount_width/2} 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/motormount.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="base_material"/>
      </visual>
      <!-- No collision element: inside robot -->
      <xacro:default_inertial mass="${motormount_mass}"/>
    </link>

    <!-- Backmotor mount -->
    <link name="back_motormount_link">
      <visual>
        <origin xyz="-${motormount_depth/2} ${motormount_width/2} 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/motormount.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="base_material"/>
      </visual>
      <!-- No collision element: inside robot -->
      <xacro:default_inertial mass="${motormount_mass}"/>
    </link>

    <!-- Right motor mount -->
    <link name="right_motormount_link">
      <visual>
        <origin xyz="-${motormount_depth/2} ${motormount_width/2} 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/motormount.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="base_material"/>
      </visual>
      <!-- No collision element: inside robot -->
      <xacro:default_inertial mass="${motormount_mass}"/>
    </link>

    <!-- Left servo -->
    <link name="left_servo_link">
      <visual>
        <origin xyz="${servo_depth/2} 0 ${servo_height/2}" rpy="0 ${pi/2} 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/servomotor_STS3215.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="servo_material"/>
      </visual>
      <!-- No collision element: inside robot -->
      <xacro:default_inertial mass="${servo_mass}"/>
    </link>

    <!-- back servo -->
    <link name="back_servo_link">
      <visual>
        <origin xyz="${servo_depth/2} 0 ${servo_height/2}" rpy="0 ${pi/2} 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/servomotor_STS3215.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="servo_material"/>
      </visual>
      <!-- No collision element: inside robot -->
      <xacro:default_inertial mass="${servo_mass}"/>
    </link>

    <!-- Right servo -->
    <link name="right_servo_link">
      <visual>
        <origin xyz="${servo_depth/2} 0 ${servo_height/2}" rpy="0 ${pi/2} 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/servomotor_STS3215.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="servo_material"/>
      </visual>
      <!-- No collision element: inside robot -->
      <xacro:default_inertial mass="${servo_mass}"/>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/omnidirectional_wheel.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="omniwheel_material"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${omniwheel_width}" radius="${omniwheel_radius}"/>
        </geometry>
      </collision>
      <!-- Assuming inertia is comparable to a cylinder -->
      <xacro:inertial_cylinder mass="${omniwheel_mass}" radius="${omniwheel_radius}" length="${omniwheel_width}"/>
    </link>

    <!-- Back wheel -->
    <link name="back_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/omnidirectional_wheel.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="omniwheel_material"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${omniwheel_width}" radius="${omniwheel_radius}"/>
        </geometry>
      </collision>
      <!-- Assuming inertia is comparable to a cylinder -->
      <xacro:inertial_cylinder mass="${omniwheel_mass}" radius="${omniwheel_radius}" length="${omniwheel_width}"/>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://lkwrbot_description/meshes/omnidirectional_wheel.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="omniwheel_material"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${omniwheel_width}" radius="${omniwheel_radius}"/>
        </geometry>
      </collision>
      <!-- Assuming inertia is comparable to a cylinder -->
      <xacro:inertial_cylinder mass="${omniwheel_mass}" radius="${omniwheel_radius}" length="${omniwheel_width}"/>
    </link>

    <!-- === Joints === -->

    <joint name="top_plate_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="top_base_plate_link"/>
      <origin xyz="0 0 0.052" rpy="0 0 0"/>
    </joint>

    <!-- left motormount joint: 60 degrees anti-clockwise from +X at radius wheel_base_radius -->
    <joint name="left_motormount_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="left_motormount_link"/>
      <origin xyz="${motormount_base_radius * cos(radial_offset)} ${motormount_base_radius * sin(radial_offset)} 0" rpy="0 0 ${radial_offset}"/>
    </joint>

    <!-- back motormount joint: 180 degrees anti-clockwise from +X at radius base_radius -->
    <joint name="back_motormount_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="back_motormount_link"/>
      <origin xyz="${motormount_base_radius * cos(radial_offset + radial_theta)} ${motormount_base_radius * sin(radial_offset + radial_theta)} 0" rpy="0 0 ${radial_offset + radial_theta}"/>
    </joint>

    <!-- right motormount joint: 300 degrees (or -60 degrees) anti-clockwise from +X at radius base_radius -->
    <joint name="right_motormount_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="right_motormount_link"/>
      <origin xyz="${motormount_base_radius * cos(radial_offset - radial_theta)} ${motormount_base_radius * sin(radial_offset - radial_theta)} 0" rpy="0 0 ${radial_offset - radial_theta}"/>
    </joint>

    <!-- left servo joint: 60 degrees anti-clockwise from +X at radius wheel_base_radius -->
    <joint name="left_servo_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="left_servo_link"/>
      <origin xyz="${servo_base_radius * cos(radial_offset)} ${servo_base_radius * sin(radial_offset)} 0" rpy="0 0 ${radial_offset}"/>
    </joint>

    <!-- back servo joint: 180 degrees anti-clockwise from +X at radius base_radius -->
   <joint name="back_servo_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="back_servo_link"/>
      <origin xyz="${servo_base_radius * cos(radial_offset + radial_theta)} ${servo_base_radius * sin(radial_offset + radial_theta)} 0" rpy="0 0 ${radial_offset + radial_theta}"/>
    </joint>

    <!-- right servo joint: 300 degrees (or -60 degrees) anti-clockwise from +X at radius base_radius -->
    <joint name="right_servo_joint" type="fixed">
      <parent link="bottom_base_plate_link"/>
      <child link="right_servo_link"/>
      <origin xyz="${servo_base_radius * cos(radial_offset - radial_theta)} ${servo_base_radius * sin(radial_offset - radial_theta)} 0" rpy="0 0 ${radial_offset - radial_theta}"/>
    </joint>


    <!-- left wheel joint: 60 degrees anti-clockwise from +X at radius wheel_base_radius -->
    <joint name="left_wheel_joint" type="continuous">
      <parent link="bottom_base_plate_link"/>
      <child link="left_wheel_link"/>
      <origin xyz="${wheel_base_radius * cos(radial_offset)} ${wheel_base_radius * sin(radial_offset)} ${wheel_base_offset_z}" rpy="0 ${pi/2} ${radial_offset}"/>
      <axis xyz="0 0 1"/>
      <limit effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
    </joint>

    <!-- back wheel joint: 180 degrees anti-clockwise from +X at radius base_radius -->
    <joint name="back_wheel_joint" type="continuous">
      <parent link="bottom_base_plate_link"/>
      <child link="back_wheel_link"/>
      <origin xyz="${wheel_base_radius * cos(radial_offset + radial_theta)} ${wheel_base_radius * sin(radial_offset + radial_theta)} ${wheel_base_offset_z}" rpy="0 ${pi/2} ${radial_offset + radial_theta}"/>
      <axis xyz="0 0 1"/>
      <limit effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
    </joint>

    <!-- right wheel joint: 300 degrees (or -60 degrees) anti-clockwise from +X at radius base_radius -->
    <joint name="right_wheel_joint" type="continuous">
      <parent link="bottom_base_plate_link"/>
      <child link="right_wheel_link"/>
      <origin xyz="${wheel_base_radius * cos(radial_offset - radial_theta)} ${wheel_base_radius * sin(radial_offset - radial_theta)} ${wheel_base_offset_z}" rpy="0 ${pi/2} ${radial_offset - radial_theta}"/>
      <axis xyz="0 0 1"/>
      <limit effort="${max_torque_nm}" velocity="${max_velocity_rads}"/>
    </joint>

  </xacro:macro>

</robot>
